# Backend environment example
PORT=4000

# Prisma / MongoDB connection string (Replica Set)
# For local development with Docker replica set
DATABASE_URL="mongodb://localhost:27017/greentrade?replicaSet=rs0&directConnection=true"

# Legacy variable (optional)
MONGODB_URI="mongodb://localhost:27017/greentrade?replicaSet=rs0&directConnection=true"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudinary
CLOUDINARY_URL=

# JWT secret
JWT_SECRET=change_me
