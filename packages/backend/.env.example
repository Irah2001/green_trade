# Backend environment example
PORT=4000
API_URL=http://localhost:4000

# Prisma / MongoDB connection string (Replica Set)
# For local development with Docker replica set
DATABASE_URL="mongodb://localhost:27017/greentrade?replicaSet=rs0&directConnection=true"

# Legacy variable (optional)
MONGODB_URI="mongodb://localhost:27017/greentrade?replicaSet=rs0&directConnection=true"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudinary
CLOUDINARY_URL=

# JWT secret
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,https://my-app.vercel.app

# Email configuration credentials (Brevo for production emails)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=email@smtp-brevo.com
EMAIL_PASSWORD=email_password
EMAIL_FROM=email@gmail.com

# Stripe
STRIPE_SECRET_KEY=stripe_secret_key
STRIPE_API_VERSION=2026-02-25.clover
FRONTEND_URL=http://localhost:5001